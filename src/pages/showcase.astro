    <div class="section-label">作品</div>
    <h1>作品</h1>
    <p>这里整理我正在维护、学习或复盘的项目与内容系列。</p>
  </section>

  <section class="work" aria-label="作品列表">
    <WorkList />
  </section>
</BaseLayout>
