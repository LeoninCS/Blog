---
const nav = [
  {
    href: '/',
    label: '主页',
    match: '/',
    icon: 'home'
  },
  {
    href: '/posts/',
    label: '文章',
    match: '/posts',
    icon: 'posts'
  },
  {
    href: '/showcase/',
    label: '作品',
    match: '/showcase',
    icon: 'showcase'
  },
  {
    href: '/about/',
    label: '关于',
    match: '/about',
    icon: 'about'
  }
];

const current = Astro.url.pathname;
const isActive = (item: (typeof nav)[number]) => {
  if (item.match === '/') return current === '/';
  return current.startsWith(item.match);
};
---

<header class="site-header" id="main-header">
  <a href="/" class="wordmark">LeoninCS’s Blog</a>
  <div class="header-right">
    <nav aria-label="主导航" class="nav">
      {nav.map((item) => (
        <a href={item.href} class:list={[{ active: isActive(item) }]} aria-current={isActive(item) ? 'page' : undefined}>
          {item.icon === 'home' && (
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 16 16">
              <path d="M2.5 6.5 8 2l5.5 4.5V13a1 1 0 0 1-1 1h-2.5v-4h-4v4H3.5a1 1 0 0 1-1-1Z"></path>
            </svg>
          )}
          {item.icon === 'posts' && (
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 16 16">
              <path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9.5a.5.5 0 0 1-.5-.5V3a.5.5 0 0 1 .5-.5Z"></path>
              <path d="M10 2.5V5.5h3"></path>
              <path d="M5.5 8.5h5"></path>
              <path d="M5.5 11h3.5"></path>
            </svg>
          )}
          {item.icon === 'showcase' && (
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 16 16">
              <rect height="8.5" rx="1" width="12" x="2" y="4.5"></rect>
              <path d="M5.5 4.5V3a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v1.5"></path>
            </svg>
          )}
          {item.icon === 'about' && (
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 16 16">
              <circle cx="8" cy="6" r="2.5"></circle>
              <path d="M3 13c.6-2.4 2.6-3.5 5-3.5s4.4 1.1 5 3.5"></path>
            </svg>
          )}
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
    <button aria-label="切换主题" class="theme-toggle" id="theme-toggle" type="button">
      <span class="icon" aria-hidden="true"></span>
      <span class="label"></span>
    </button>
  </div>
</header>
