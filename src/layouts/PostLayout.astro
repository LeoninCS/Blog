---
import BaseLayout from './BaseLayout.astro';
import type { BlogPost } from '../lib/posts';
import { formatDate, readTime } from '../lib/posts';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const metaItems = [...post.data.categories, ...post.data.tags.filter((tag) => !post.data.categories.includes(tag))];
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-main">
    <header class="post-header">
      <a class="back-link" href="/posts/">← 全部文章</a>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="post-detail-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>·</span>
        <span>{readTime(post)} 分钟阅读</span>
      </div>
      {metaItems.length > 0 && (
        <div class="tag-row">
          {metaItems.slice(0, 5).map((item) => <span>{item}</span>)}
        </div>
      )}
    </header>

    {post.data.cover && <img class="post-cover" src={post.data.cover} alt="" loading="eager" />}

    <div class="rule"></div>
    <div class="post-article">
      <slot />
    </div>
  </article>
</BaseLayout>
